{
  "manifest_version": 3,
  "name": "Lancor Search OS",
  "version": "1.1",
  "description": "Auto-syncs LinkedIn profiles to Lancor Search OS. Also syncs to Airtable if configured.",
  "browser_specific_settings": {
    "gecko": {
      "id": "ats-scraper@extension",
      "strict_min_version": "121.0"
    }
  },
  "permissions": ["activeTab", "scripting", "storage", "tabs"],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://api.airtable.com/*",
    "http://localhost:*/*"
  ],
  "content_scripts": [{
    "matches": ["https://www.linkedin.com/in/*", "https://www.linkedin.com/talent/profile/*"],
    "js": ["content.js"],
    "css": ["styles.css"],
    "run_at": "document_idle"
  }],
  "background": {
    "service_worker": "background.js",
    "scripts": ["background.js"]
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "ATS LinkedIn Scraper"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  }
}
